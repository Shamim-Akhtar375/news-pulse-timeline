# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
# Defaults to sqlite locally. Replace with Supabase PostgreSQL URL in production.
# Example: postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=sqlite:///./news_pulse.db

# Machine Learning / Clustering Parameters
# Cosine similarity threshold (0.0 to 1.0) for grouping articles.
# Lower = larger, broader clusters; Higher = tighter, near-duplicate clusters.
SIMILARITY_THRESHOLD=0.40

# RSS Feeds to Monitor (comma-separated list of URLs)
# If left blank, defaults to a list of tech and news feeds: TechCrunch, NYTimes, BBC News.
RSS_FEEDS=https://techcrunch.com/feed/,https://rss.nytimes.com/services/xml/rss/nyt/World.xml,https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml,https://feeds.bbci.co.uk/news/rss.xml,https://feeds.bbci.co.uk/news/technology/rss.xml
